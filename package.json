{
  "name": "getcito",
  "version": "0.2.13",
  "private": true,
  "license": "MIT",
  "packageManager": "pnpm@11.10.0",
  "engines": {
    "node": "24.x"
  },
  "scripts": {
    "dev": "turbo dev",
    "build": "turbo build",
    "lint": "turbo lint",
    "test": "turbo test",
    "format": "biome format --write .",
    "knip": "knip",
    "getcito": "tsx apps/cli/src/index.ts",
    "cli:link": "npm unlink -g getcito-cli || true && pnpm -C apps/cli build && (cd apps/cli && npm link)",
    "cli:unlink": "npm unlink -g getcito-cli",
    "changeset": "changeset",
    "version-packages": "changeset version && node scripts/sync-root-version.mjs",
    "release": "pnpm build && changeset publish",
    "test:e2e": "pnpm --filter e2e test:e2e",
    "test:e2e-local": "bash e2e/run-local.sh",
    "license-check": "node scripts/check-licenses.mjs"
  },
  "devDependencies": {
    "@biomejs/biome": "2.5.4",
    "@changesets/cli": "^2.31.1",
    "knip": "^6.27.0",
    "tsx": "^4.23.1",
    "turbo": "^2.10.5",
    "typescript": "^6.0.3"
  }
}


